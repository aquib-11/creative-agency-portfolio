{
  "name": "backend",
  "version": "1.0.0",
  "description": "Medical scientific store",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "setup-project": "cd ../frontend && npm install && cd ../backend && npm install",
    "setup-production-app": "cd ../frontend && npm install && npm run build && cd ../backend && npm install",
    "server": "nodemon server.js",
    "client": "cd ../frontend && npm run dev",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/lib-storage": "^3.1023.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.1.2",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "datauri": "^4.1.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jose": "^6.0.12",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "nanoid": "^5.1.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "author": "",
  "license": "ISC"
}
